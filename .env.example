# =========================================================================
# Crypto AutoPost — environment variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env
#
# Load into your shell with (bash/zsh):
#   set -a; source .env; set +a
#
# On Windows PowerShell:
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#][^=]*)=(.*)$')
#     { [Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }
# =========================================================================

# --- Copywriter (Agent 3) --------------------------------------------------
# Anthropic API key — required for the Copywriter stage.
# Get one at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional: override the default model (default: claude-sonnet-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5

# --- News Scout (Agent 1) --------------------------------------------------
# Optional — without it we fall back to CoinDesk RSS + Cointelegraph RSS only.
# Free tier: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# Optional — LunarCrush social-momentum signal. Boosts importance of stories
# whose tickers are in the trending top-10 and adds up to 2 synthetic
# "social-momentum" candidates for pure-momentum tickers with no news.
# Get a key at https://lunarcrush.com/developers (Individual plan).
LUNARCRUSH_API_KEY=

# --- Metrics receiver (optional, for auto-populating metrics.json) --------
# Shared secret for the Make.com inbound scenario that POSTs X/TG metrics
# back to the local receiver. Any non-empty string you pick.
METRICS_WEBHOOK_SECRET=
# Bind address for the receiver. Default: 127.0.0.1:8787
# METRICS_RECEIVER_BIND=127.0.0.1:8787

# --- Publisher (Agent 6) ---------------------------------------------------
# Telegram bot token from @BotFather (e.g. 123456:AAB-...)
TELEGRAM_BOT_TOKEN=

# Channel or chat to post in — either the @channelname or the numeric chat ID.
# For a private group, add the bot as admin first and use the -100... chat id.
TELEGRAM_CHAT_ID=@YourCryptoChannel

# Make.com custom-webhook URL — see config/make_blueprints/README.md to set up.
# Looks like: https://hook.eu1.make.com/abc123...
MAKE_X_WEBHOOK_URL=

# --- Paths / misc ---------------------------------------------------------
# Override the queue directory (default: ./queue)
# AUTOPOST_QUEUE=/absolute/path/to/queue
